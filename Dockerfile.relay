FROM rust:latest AS builder

WORKDIR /app
COPY . .
RUN cargo build --release --no-default-features --features relay --bin txxxt-relay

# --- Runtime (ubuntu 24.04 = GLIBC 2.39) ---
FROM ubuntu:24.04
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/txxxt-relay /usr/local/bin/
CMD ["txxxt-relay"]
